generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DegreeLevel {
  BACHELOR
  MASTER
  PHD
}

enum SemesterStatus {
  ONGOING
  FINISHED
}

enum PostVisibility {
  FRIENDS
  PUBLIC
}

enum ProfileVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum TwoFactorMethod {
  EMAIL
  PHONE
}

enum PostReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum VerificationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IdentityDocumentType {
  ID_CARD
  PASSPORT
  OTHER
}

enum SemesterVerificationStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  pendingEmail  String?
  image         String?
  role          UserRole  @default(USER)
  isBlueVerified Boolean  @default(false)
  blueVerifiedAt DateTime?
  blueVerifiedById String?
  passwordHash  String?
  twoFactorEnabled Boolean @default(false)
  twoFactorMethod  TwoFactorMethod @default(EMAIL)
  twoFactorPhone   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  blueVerifiedBy User? @relation("BlueBadgeVerifier", fields: [blueVerifiedById], references: [id], onDelete: SetNull)
  blueVerifiedUsers User[] @relation("BlueBadgeVerifier")

  profile   Profile?
  semesters Semester[]
  posts     Post[]
  postLikes PostLike[]
  comments  PostComment[]
  commentReactions PostCommentReaction[]
  postMentions PostMention[] @relation("MentionedInPost")
  commentMentions CommentMention[] @relation("MentionedInComment")

  profileVerificationRequests ProfileVerificationRequest[] @relation("ProfileVerificationRequester")
  reviewedProfileVerifications ProfileVerificationRequest[] @relation("ProfileVerificationReviewer")
  reviewedSemesters Semester[] @relation("SemesterReviewedBy")
  adminActions AdminActionLog[] @relation("AdminActor")
  targetedAdminActions AdminActionLog[] @relation("AdminTarget")

  accounts Account[]
  sessions Session[]

  sentFriendRequests     FriendRequest[]     @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[]     @relation("ReceivedFriendRequests")
  visibleSemesters       SemesterVisibility[] @relation("SemesterVisibleTo")
}

model Profile {
  id                  String      @id @default(cuid())
  userId              String      @unique
  firstName           String
  lastName            String
  fatherName          String
  university          String
  faculty             String
  department          String
  degreeLevel         DegreeLevel @default(BACHELOR)
  yearOfEnrollment    Int
  dateOfBirth         DateTime
  totalSemesters      Int         @default(8)
  minimumPassingMarks Float       @default(50)
  idealPercentage     Float?
  profileVisibility   ProfileVisibility @default(FRIENDS)
  allowFriendRequests Boolean      @default(true)
  defaultPostVisibility PostVisibility @default(FRIENDS)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Semester {
  id        String   @id @default(cuid())
  userId    String
  index     Int
  name      String?
  status    SemesterStatus @default(FINISHED)
  verificationStatus SemesterVerificationStatus @default(NOT_REQUESTED)
  verificationDocumentUrl String?
  verificationDocumentName String?
  verificationRequestedAt DateTime?
  verificationReviewedAt DateTime?
  verificationReviewNote String?
  verificationReviewedById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationReviewedBy User? @relation("SemesterReviewedBy", fields: [verificationReviewedById], references: [id], onDelete: SetNull)
  subjects    Subject[]
  visibility  SemesterVisibility[]
  postShares  PostSharedSemester[]

  @@unique([userId, index])
  @@index([verificationStatus])
}

model Post {
  id                        String         @id @default(cuid())
  userId                    String
  content                   String
  visibility                PostVisibility @default(FRIENDS)
  includeOverallPercentage  Boolean        @default(false)
  overallPercentageSnapshot Float?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes           PostLike[]
  comments        PostComment[]
  media           PostMedia[]
  mentions        PostMention[]
  sharedSemesters PostSharedSemester[]

  @@index([createdAt(sort: Desc)])
}

model PostSharedSemester {
  id         String   @id @default(cuid())
  postId     String
  semesterId String
  createdAt  DateTime @default(now())

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([postId, semesterId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reactionType PostReactionType @default(LIKE)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent PostComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PostComment[] @relation("CommentReplies")
  reactions PostCommentReaction[]
  mentions CommentMention[]

  @@index([postId, createdAt(sort: Desc)])
  @@index([parentId, createdAt(sort: Asc)])
}

model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  url       String
  fileName  String?
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt(sort: Asc)])
}

model PostCommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  reactionType PostReactionType @default(LIKE)
  createdAt DateTime @default(now())

  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model PostMention {
  id              String   @id @default(cuid())
  postId          String
  mentionedUserId String
  createdAt       DateTime @default(now())

  post          Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionedUser User @relation("MentionedInPost", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId, createdAt(sort: Desc)])
}

model CommentMention {
  id              String   @id @default(cuid())
  commentId       String
  mentionedUserId String
  createdAt       DateTime @default(now())

  comment       PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User        @relation("MentionedInComment", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId, createdAt(sort: Desc)])
}

model ProfileVerificationRequest {
  id           String                    @id @default(cuid())
  userId       String
  documentType IdentityDocumentType
  documentUrl  String
  documentName String?
  status       VerificationRequestStatus @default(PENDING)
  reviewedById String?
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  user       User  @relation("ProfileVerificationRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ProfileVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model AdminActionLog {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String?
  action       String
  entityType   String?
  entityId     String?
  detailsJson  String?
  createdAt    DateTime @default(now())

  admin      User  @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser User? @relation("AdminTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
}

model Subject {
  id                   String   @id @default(cuid())
  semesterId           String
  name                 String
  credits              Float
  code                 String?
  teacherName          String?
  lectureMaterialsJson String?
  chance               Int
  score                Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model SemesterVisibility {
  id         String   @id @default(cuid())
  semesterId String
  viewerId   String
  createdAt  DateTime @default(now())

  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  viewer   User     @relation("SemesterVisibleTo", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([semesterId, viewerId])
}

model FriendRequest {
  id          String              @id @default(cuid())
  senderId    String
  recipientId String
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  sender    User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ReceivedFriendRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([senderId, recipientId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
